# =============================================
# DATABASE
# =============================================
DATABASE_URL=postgresql://user:password@localhost:5432/sindico_gestao
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================
# AUTHENTICATION
# =============================================
JWT_SECRET=replace_with_256bit_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
BCRYPT_ROUNDS=12

# =============================================
# CLAUDE / ANTHROPIC
# =============================================
ANTHROPIC_API_KEY=sk-ant-replace_me
CLAUDE_MODEL=claude-opus-4-5
AI_MAX_TOKENS=2048

# =============================================
# WHATSAPP (Baileys)
# =============================================
WA_SESSION_ENCRYPTION_KEY=replace_with_32byte_hex
WA_RECONNECT_INTERVAL_MS=30000

# =============================================
# APP
# =============================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
INTERNAL_API_KEY=replace_with_secret_for_internal_webhooks

# =============================================
# CRON JOBS
# =============================================
CRON_COMPLIANCE_ALERTS=0 8 * * *
CRON_AI_DIGEST=0 7 * * *
CRON_FINANCIAL_REMINDERS=0 9 * * 1
